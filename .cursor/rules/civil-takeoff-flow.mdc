## PDF Page Extraction with pdf-lib

```javascript
import { PDFDocument } from 'pdf-lib';

async function extractPdfPage(fileBuffer, pageNum) {
  const srcDoc = await PDFDocument.load(fileBuffer);
  const newDoc = await PDFDocument.create();
  const [copiedPage] = await newDoc.copyPages(srcDoc, [pageNum - 1]); // 0-indexed
  newDoc.addPage(copiedPage);
  return Buffer.from(await newDoc.save());
}

async function getPdfPageCount(fileBuffer) {
  const doc = await PDFDocument.load(fileBuffer);
  return doc.getPageCount();
}
```

**Install:** `npm install pdf-lib` in `/server`


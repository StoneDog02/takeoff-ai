# Anthropic (required for takeoff)
ANTHROPIC_API_KEY=

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server
PORT=3001

# Employee invite emails (Resend)
# Required for sending invite emails when adding employees or inviting to portal
RESEND_API_KEY=
APP_ORIGIN=http://localhost:5173
# Optional: INVITE_EMAIL_FROM=App Name <noreply@yourdomain.com>
# Optional: INVITE_EMAIL_SUBJECT=You're invited to join [App name]

# Contractors: use mock data to preview the Contractors page (set to true to enable)
# VITE_USE_CONTRACTORS_MOCK=true

# Optional: for production when API is on another host (e.g. Render)
# VITE_API_URL=https://your-api.onrender.com

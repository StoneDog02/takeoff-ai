# Anthropic (required for takeoff)
ANTHROPIC_API_KEY=

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server
PORT=3001

# Employee invite emails (Resend)
# Required for sending invite emails when adding employees or inviting to portal
RESEND_API_KEY=
APP_ORIGIN=http://localhost:5173
# INVITE_EMAIL_FROM: required for sending to real addresses. Default onboarding@resend.dev
# only delivers to your Resend account's email; verify a domain and set e.g.:
# INVITE_EMAIL_FROM=Your App <noreply@yourdomain.com>
# Optional: INVITE_EMAIL_SUBJECT=You're invited to join [App name]

# Contractors: use mock data to preview the Contractors page (set to true to enable)
# VITE_USE_CONTRACTORS_MOCK=true

# QuickBooks (optional)
# QUICKBOOKS_CLIENT_ID=
# QUICKBOOKS_CLIENT_SECRET=
# Redirect URI must match the value registered in your Intuit app (e.g. http://localhost:3001/api/quickbooks/callback)
# QUICKBOOKS_REDIRECT_URI=http://localhost:3001/api/quickbooks/callback
# Set to production to use live QuickBooks (default: sandbox)
# QUICKBOOKS_ENV=production
# Optional: sign OAuth state (defaults to SUPABASE_JWT_SECRET)
# QUICKBOOKS_STATE_SECRET=

# Optional: for production when API is on another host (e.g. Render)
# VITE_API_URL=https://your-api.onrender.com
